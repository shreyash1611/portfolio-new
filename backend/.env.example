# Copy this file to .env and fill in your own values.
# .env is gitignored -- never commit real tokens.

# Server
PORT=8080
ALLOWED_ORIGIN=http://localhost:5173
# How long fetched platform stats stay cached before a background refresh.
CACHE_TTL=15m

# Your GitHub username (used to fetch your contribution calendar).
GITHUB_USERNAME=your-github-username

# GitHub's GraphQL API requires auth even for public data.
# Create a classic token at https://github.com/settings/tokens (Generate new token -> classic).
# No scopes/checkboxes need to be selected for public data -- an unscoped token is enough.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your LeetCode username, exactly as it appears in your profile URL.
LEETCODE_USERNAME=your-leetcode-username

# Your Codeforces handle, exactly as it appears in your profile URL.
CODEFORCES_HANDLE=your-codeforces-handle
